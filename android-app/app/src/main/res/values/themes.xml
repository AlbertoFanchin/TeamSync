<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TeamSync" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">#0A0A0A</item>
        <item name="android:navigationBarColor">#0A0A0A</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <style name="Theme.TeamSync.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A0A0A</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.TeamSync</item>
    </style>
</resources>
